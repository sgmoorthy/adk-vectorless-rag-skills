# Vectorless RAG Engine Environment Variables

DATABASE_URL=postgresql+asyncpg://admin:pass@localhost:5432/rag
SYNC_DATABASE_URL=postgresql://admin:pass@localhost:5432/rag

# Application Secrets
SECRET_KEY=dev_secret_key_change_me

# Tenant Mapping 
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# ADK Telemetry settings
ADK_TELEMETRY_ENABLED=true
ADK_TRACE_LEVEL=DEBUG
